# If you prefer the allow list template instead of the deny list, see community template:
# https://github.com/github/gitignore/blob/main/community/Golang/Go.AllowList.gitignore
#
# Binaries for programs and plugins
*.exe
*.exe~
*.dll
*.so
*.dylib

# Test binary, built with `go test -c`
*.test

# Code coverage profiles and other test artifacts
*.out
coverage.*
*.coverprofile
profile.cov

# Dependency directories (remove the comment below to include it)
# vendor/

# Go workspace file
go.work
go.work.sum

# env file
.env

# Editor/IDE
# .idea/
# .vscode/
# Beads / Dolt files (added by bd init)
.dolt/
*.db
.beads-credential-key

# Gas City beads workspace (track only config + metadata)
.beads/*
!.beads/config.yaml
!.beads/metadata.json

# macOS junk
.DS_Store

# Python build artifacts (created when running module-level smoke
# tests under arbiter/src/ or petitioner/src/).
__pycache__/
*.pyc
*.pyo

# Session / runtime state
.runtime/
.gc/tmp/

# Daemon binaries, datadirs, credentials. Subdirs of arbiter/ are
# non-source by default; only arbiter/src/ holds the auditable code,
# so enumerate the ignored subdirs rather than ignoring arbiter/ as a
# whole (git cannot re-include children of an excluded directory).
arbiter/bin/
arbiter/bitcoin/
arbiter/lnd/
arbiter/data/

# Local Go SDK / module cache
go/
go-cache/

# Embedded repo (separate project, has its own .git)
first-game/

# Symlinks to skills installed outside this repo (absolute paths, machine-specific)
.claude/skills/core.*

# Test-harness ephemera (only scripts/ at top-level is source)
test-harness/bin/
test-harness/cache/
test-harness/downloads/
test-harness/ldk-data/
test-harness/python/
test-harness/state/
test-harness/venv/

# Credentials (defense-in-depth, in case any escape the directory ignores)
*.macaroon
*.tls.cert
*.key
*.pem
.env
.env.*
