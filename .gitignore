# If you prefer the allow list template instead of the deny list, see community template:
# https://github.com/github/gitignore/blob/main/community/Golang/Go.AllowList.gitignore
#
# Binaries for programs and plugins
*.exe
*.exe~
*.dll
*.so
*.dylib

# Test binary, built with `go test -c`
*.test

# Code coverage profiles and other test artifacts
*.out
coverage.*
*.coverprofile
profile.cov

# Dependency directories (remove the comment below to include it)
# vendor/

# Go workspace file
go.work
go.work.sum

# env file
.env

# Editor/IDE
# .idea/
# .vscode/
# Beads / Dolt files (added by bd init)
.dolt/
*.db
.beads-credential-key

# Gas City beads workspace (track only config + metadata)
.beads/*
!.beads/config.yaml
!.beads/metadata.json

# macOS junk
.DS_Store

# Python build artifacts (created when running module-level smoke
# tests under arbiter/src/ or petitioner/src/).
__pycache__/
*.pyc
*.pyo

# Session / runtime state
.runtime/
.gc/tmp/

# Per design-docs/origin/06--2026-05-24-0623-arb-auditability.md §3,
# arbiter/ now holds three tracked subtrees (src/, config/, bin/) plus
# four gitignored runtime subtrees (state/, bitcoin/, lnd/, data/).
# arbiter/.gitignore inside the arbiter tree is the load-bearing copy
# (it is what the continuous git snapshot reads when run from the
# deployed arbiter root). These root-level entries are defense in
# depth for this monorepo so the runtime subtrees do not leak into
# checkins from the repo root.
arbiter/state/
arbiter/bitcoin/
arbiter/lnd/
arbiter/data/

# Local Go SDK / module cache
go/
go-cache/

# Embedded repo (separate project, has its own .git)
first-game/

# Symlinks to skills installed outside this repo (absolute paths, machine-specific)
.claude/skills/core.*

# Test-harness ephemera (only scripts/ at top-level is source)
test-harness/bin/
test-harness/cache/
test-harness/downloads/
test-harness/ldk-data/
test-harness/python/
test-harness/state/
test-harness/venv/

# Credentials (defense-in-depth, in case any escape the directory ignores)
*.macaroon
*.tls.cert
*.key
*.pem
.env
.env.*
