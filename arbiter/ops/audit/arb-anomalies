#!/bin/sh
# arb-anomalies: heuristic checks against the recent snapshot history.
# Per design-docs/origin/06--2026-05-24-0623-arb-auditability.md §8.
#
# Read-only. Runs a fixed set of cheap heuristics and flags anything
# that does not fit normal operation. Suggests follow-up commands but
# does not act on anything. The heuristics intentionally over-flag:
# the cost of a false positive is one extra arb-show; the cost of a
# false negative is missing real tampering.
#
# Window: the last 7 days (override with $ARB_ANOMALIES_DAYS).
# Night hours treated as anomalous: 00:00-06:00 in the snapshot's
# UTC timestamps (override with $ARB_NIGHT_START / $ARB_NIGHT_END).

set -e
here="$(cd "$(dirname "$0")" && pwd)"
ARBITER_ROOT="${ARBITER_ROOT:-$(cd "$here/../.." && pwd)}"
cd "$ARBITER_ROOT"

# Refuse if arbiter/ is not its own git repo top-level: walking a
# parent repo's history would surface unrelated commits. Bootstrap
# per arbiter/ops/README.md.
if [ ! -e "$ARBITER_ROOT/.git" ]; then
    printf "Error: %s is not a git repository.\n" "$ARBITER_ROOT" >&2
    printf "Bootstrap: cd %s && git init && git add -A && git commit -m 'initial'\n" "$ARBITER_ROOT" >&2
    exit 1
fi

days="${ARB_ANOMALIES_DAYS:-7}"
night_start="${ARB_NIGHT_START:-0}"   # inclusive lower bound (hour, UTC)
night_end="${ARB_NIGHT_END:-6}"       # exclusive upper bound (hour, UTC)

printf "Checking for anomalies in the last %d days...\n\n" "$days"

since="${days} days ago"

tmp="$(mktemp -t arb-anom.XXXXXX)"
trap 'rm -f "$tmp"' EXIT
git log --since="$since" --reverse --pretty=tformat:'%H %ct %cI' > "$tmp" || true

flags="$(mktemp -t arb-anom-flags.XXXXXX)"
trap 'rm -f "$tmp" "$flags"' EXIT
: > "$flags"

# Heuristic 1: commits at unusual hours.
night_count=0
while read -r hash epoch iso; do
    [ -z "$hash" ] && continue
    hour="$(echo "$iso" | cut -c12-13)"
    h=$((10#${hour}))
    if [ "$h" -ge "$night_start" ] && [ "$h" -lt "$night_end" ]; then
        printf "FLAG  Commit at %s (between %02d:00 and %02d:00 UTC).\n" \
            "$(echo "$iso" | cut -c1-16 | tr 'T' ' ')" "$night_start" "$night_end" >> "$flags"
        night_count=$((night_count + 1))
    fi
done < "$tmp"
if [ "$night_count" -eq 0 ]; then
    printf "  OK    No commits at unusual hours (%02d:00-%02d:00 UTC).\n" \
        "$night_start" "$night_end"
else
    printf "  FLAG  %d commit%s at unusual hours (%02d:00-%02d:00 UTC).\n" \
        "$night_count" "$([ "$night_count" -eq 1 ] && echo "" || echo "s")" \
        "$night_start" "$night_end"
fi

# Heuristic 2: snapshot gaps > 2 minutes.
# Walks consecutive commits; a gap > 120s means the cron missed
# firings. Quiescent stretches with nothing to commit also produce no
# commits, so this is a noisy heuristic - it flags both "cron stopped"
# and "nothing changed for a while," but the operator can disambiguate
# by looking at the gap window.
gaps=0
prev_epoch=""
while read -r hash epoch iso; do
    [ -z "$hash" ] && continue
    if [ -n "$prev_epoch" ]; then
        delta=$((epoch - prev_epoch))
        if [ "$delta" -gt 120 ]; then
            mins=$((delta / 60))
            printf "FLAG  %d-minute gap ending at %s (cron fires every 60s).\n" \
                "$mins" "$(echo "$iso" | cut -c1-16 | tr 'T' ' ')" >> "$flags"
            gaps=$((gaps + 1))
        fi
    fi
    prev_epoch="$epoch"
done < "$tmp"
if [ "$gaps" -eq 0 ]; then
    printf "  OK    No snapshot gaps over 2 minutes.\n"
else
    printf "  FLAG  %d snapshot gap%s over 2 minutes (cron may have stalled or nothing changed).\n" \
        "$gaps" "$([ "$gaps" -eq 1 ] && echo "" || echo "s")"
fi

# Heuristic 3: bin/ change without a corresponding src/ change in the
# same commit. The binary on disk should be a function of the source
# in the same snapshot; a bin/ swap without src/ means something
# replaced the binary directly.
bin_only=0
while read -r hash epoch iso; do
    [ -z "$hash" ] && continue
    files="$(git show --name-only --format= "$hash" | sed '/^$/d')"
    has_bin="$(printf '%s\n' "$files" | grep -c '^bin/' || true)"
    has_src="$(printf '%s\n' "$files" | grep -c '^src/' || true)"
    if [ "$has_bin" -gt 0 ] && [ "$has_src" = "0" ]; then
        printf "FLAG  bin/ change at %s without any src/ change in the same commit.\n" \
            "$(echo "$iso" | cut -c1-16 | tr 'T' ' ')" >> "$flags"
        bin_only=$((bin_only + 1))
    fi
done < "$tmp"
if [ "$bin_only" -eq 0 ]; then
    printf "  OK    No bin/ swaps without matching src/ changes.\n"
else
    printf "  FLAG  %d bin/ swap%s without matching src/ changes.\n" \
        "$bin_only" "$([ "$bin_only" -eq 1 ] && echo "" || echo "s")"
fi

# Heuristic 4: src/ or bin/ change at the same time as a config/
# change. Deploys should not be editing operator config in the same
# commit; if they do, the boundary §3 relies on is leaking.
mixed=0
while read -r hash epoch iso; do
    [ -z "$hash" ] && continue
    files="$(git show --name-only --format= "$hash" | sed '/^$/d')"
    has_cfg="$(printf '%s\n' "$files" | grep -c '^config/' || true)"
    has_code="$(printf '%s\n' "$files" | grep -cE '^(src|bin)/' || true)"
    if [ "$has_cfg" -gt 0 ] && [ "$has_code" -gt 0 ]; then
        printf "FLAG  Mixed config + code change at %s (config edits should not touch code, and vice versa).\n" \
            "$(echo "$iso" | cut -c1-16 | tr 'T' ' ')" >> "$flags"
        mixed=$((mixed + 1))
    fi
done < "$tmp"
if [ "$mixed" -eq 0 ]; then
    printf "  OK    No commits mixing config edits with deploys.\n"
else
    printf "  FLAG  %d commit%s mixing config edits with deploys.\n" \
        "$mixed" "$([ "$mixed" -eq 1 ] && echo "" || echo "s")"
fi

total=$((night_count + gaps + bin_only + mixed))
if [ "$total" -eq 1 ]; then
    printf "\n1 flag.\n"
else
    printf "\n%d flags.\n" "$total"
fi
if [ "$total" -gt 0 ]; then
    printf "\nDetails:\n"
    sed 's/^/  /' "$flags"
    printf "\nReview with arb-show '<timestamp>' on any flag worth investigating.\n"
fi
