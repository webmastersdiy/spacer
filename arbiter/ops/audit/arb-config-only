#!/bin/sh
# arb-config-only: only operator-driven config edits. Hides every
# code deploy. Per design-docs/origin/06--2026-05-24-0623-arb-auditability.md §8.
#
# Answers: "Who has been editing my YAML?" Output is most-recent-first
# so the latest activity is at the top of the screen.
#
# No flags. Honors $ARB_AUDIT_LIMIT for the maximum number of entries
# (default 50); useful only for very long histories.

set -e
here="$(cd "$(dirname "$0")" && pwd)"
ARBITER_ROOT="${ARBITER_ROOT:-$(cd "$here/../.." && pwd)}"
cd "$ARBITER_ROOT"

# Refuse if arbiter/ is not its own git repo top-level: walking a
# parent repo's history would surface unrelated commits. Bootstrap
# per arbiter/ops/README.md.
if [ ! -e "$ARBITER_ROOT/.git" ]; then
    printf "Error: %s is not a git repository.\n" "$ARBITER_ROOT" >&2
    printf "Bootstrap: cd %s && git init && git add -A && git commit -m 'initial'\n" "$ARBITER_ROOT" >&2
    exit 1
fi

limit="${ARB_AUDIT_LIMIT:-50}"

printf "Config edits (most recent first):\n"

# git log -- config/ restricts to commits that touched config/; the
# tracked README.md plus any YAML the operator drops in are inside
# this path.
tmp="$(mktemp -t arb-config.XXXXXX)"
trap 'rm -f "$tmp"' EXIT
git log -n "$limit" --pretty=tformat:'%H %cI' -- config/ > "$tmp" || true

if [ ! -s "$tmp" ]; then
    printf "  (no config edits in history)\n"
    exit 0
fi

n=0
while read -r hash ts; do
    [ -z "$hash" ] && continue
    n=$((n + 1))
    date_time="$(echo "$ts" | cut -c1-16 | tr 'T' ' ')"

    # Restrict the diff stat to config/ paths only, in case a commit
    # also touched code (which arb-anomalies will flag separately).
    cfg_files="$(git show --name-only --format= "$hash" -- config/ | sed '/^$/d')"
    [ -z "$cfg_files" ] && continue

    for f in $cfg_files; do
        stat="$(git show --shortstat --format= "$hash" -- "$f" \
            | awk -F'[,()]' '{for(i=1;i<=NF;i++){gsub(/^ +| +$/,"",$i); if($i ~ /insertion/||$i ~ /deletion/){printf "%s%s", (out?", ":""), $i; out=1}}}' \
            | sed -e 's/ insertions*(+)/ lines added/' -e 's/ deletions*(-)/ lines removed/')"
        if [ -n "$stat" ]; then
            printf "  %s  %s  (%s)\n" "$date_time" "$f" "$stat"
        else
            printf "  %s  %s\n" "$date_time" "$f"
        fi
    done
done < "$tmp"
