#!/bin/sh
# arb-since <when>: what changed in the arbiter tree since <when>?
# Per design-docs/origin/06--2026-05-24-0623-arb-auditability.md §8.
#
# Wider-window variant of arb-today. Accepts whatever date forms
# git log --since accepts ("2 days ago", "last sunday", "2026-05-20",
# etc.) so the operator does not have to learn a new date language.
#
# Use this for weekly review (§9), or after a deploy / config edit
# (arb-since '5 minutes ago') to confirm the only changes in the
# window are the expected ones.

set -e
here="$(cd "$(dirname "$0")" && pwd)"
ARBITER_ROOT="${ARBITER_ROOT:-$(cd "$here/../.." && pwd)}"
cd "$ARBITER_ROOT"

# Refuse if arbiter/ is not its own git repo top-level: walking a
# parent repo's history would surface unrelated commits. Bootstrap
# per arbiter/ops/README.md.
if [ ! -e "$ARBITER_ROOT/.git" ]; then
    printf "Error: %s is not a git repository.\n" "$ARBITER_ROOT" >&2
    printf "Bootstrap: cd %s && git init && git add -A && git commit -m 'initial'\n" "$ARBITER_ROOT" >&2
    exit 1
fi

if [ $# -lt 1 ]; then
    cat >&2 <<EOF
Usage: arb-since <when>

  <when>  Any date form git log --since accepts.
          Examples: '2 days ago', 'last sunday', '2026-05-20',
                    '5 minutes ago', 'yesterday'.

EOF
    exit 2
fi
when="$1"

printf "Since %s:\n" "$when"

tmp="$(mktemp -t arb-since.XXXXXX)"
trap 'rm -f "$tmp"' EXIT
git log --since="$when" --reverse --pretty=tformat:'%H %cI' > "$tmp" || true

if [ ! -s "$tmp" ]; then
    printf "  (no changes in this window)\n"
    exit 0
fi

n=0
while read -r hash ts; do
    [ -z "$hash" ] && continue
    n=$((n + 1))

    # Full date and time so the operator can correlate across days.
    date_time="$(echo "$ts" | cut -c1-16 | tr 'T' ' ')"

    files="$(git show --name-only --format= "$hash" | sed '/^$/d')"
    cfg="$(printf '%s\n' "$files" | grep '^config/' || true)"
    src="$(printf '%s\n' "$files" | grep '^src/' || true)"
    bin_="$(printf '%s\n' "$files" | grep '^bin/' || true)"

    [ -n "$cfg" ] && {
        nfiles="$(printf '%s\n' "$cfg" | wc -l | tr -d ' ')"
        if [ "$nfiles" = "1" ]; then
            printf "  %s  config edit    %s\n" "$date_time" "$cfg"
        else
            first2="$(printf '%s\n' "$cfg" | head -n 2 | paste -sd ',' - | sed 's/,/, /g')"
            extra=$((nfiles - 2))
            if [ "$extra" -gt 0 ]; then
                printf "  %s  config edit    %s + %d more\n" "$date_time" "$first2" "$extra"
            else
                printf "  %s  config edit    %s\n" "$date_time" "$first2"
            fi
        fi
    }

    [ -n "$src" ] && {
        nfiles="$(printf '%s\n' "$src" | wc -l | tr -d ' ')"
        if [ "$nfiles" -le 1 ]; then
            printf "  %s  code deploy    %s\n" "$date_time" "$src"
        else
            first="$(printf '%s\n' "$src" | head -n 1)"
            extra=$((nfiles - 1))
            printf "  %s  code deploy    %s + %d other source file%s\n" "$date_time" "$first" "$extra" "$([ "$extra" -eq 1 ] && echo "" || echo "s")"
        fi
    }

    [ -n "$bin_" ] && {
        paths="$(printf '%s\n' "$bin_" | paste -sd ',' - | sed 's/,/, /g')"
        printf "  %s  binary update  %s\n" "$date_time" "$paths"
    }
done < "$tmp"

printf "\n%d change%s in this window.\n" "$n" "$([ "$n" -eq 1 ] && echo "" || echo "s")"
